# Example environment variables for the server
# Replace username, password and db name with your local values
DATABASE_URL=postgres://postgres:password@localhost:5432/pathment_dev

# AI provider (Groq/OpenAI-compatible)
AI_API_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
AI_BASE_URL=https://api.groq.com/openai/v1

# Free-tier-safe roadmap generation limits
AI_ROADMAP_MAX_TOTAL_TOKENS=5800
AI_ROADMAP_OUTPUT_TOKENS=1200
AI_ROADMAP_MIN_OUTPUT_TOKENS=500
AI_ROADMAP_CHUNK_WEEKS=2

# Registration invites
# Default invite expiration in hours when admin does not specify a custom value
REGISTRATION_INVITE_EXPIRY_HOURS=72

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Pathment <noreply@pathment.me>
# Optional reply-to for outbound emails
RESEND_REPLY_TO=support@pathment.me
# Disable matrix/bulk notification emails by default for free-tier safety
EMAIL_NOTIFICATION_EMAILS_ENABLED=false
EMAIL_DISABLED_EVENTS=
EMAIL_DAILY_LIMIT=100
EMAIL_DAILY_LIMIT_PER_RECIPIENT=20
